{
  "name": "green-rice-web-temp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "check:arch": "npx tsx scripts/check-architecture.ts",
    "sync:manifests": "npx tsx scripts/sync-functions-manifests.ts",
    "check:manifest-freshness": "npx tsx scripts/check-manifest-freshness.ts",
    "check:traits-schema": "npx tsx scripts/check-traits-schema.ts",
    "check:cross-language": "npx tsx scripts/check-cross-language-parity.ts",
    "check:download-bundles": "npx tsx scripts/verify-download-bundles.ts",
    "check:download-determinism": "functions-python/venv/bin/python3 scripts/check-download-determinism.py",
    "generate:downloads": "functions-python/venv/bin/python3 scripts/generate-download-bundles.py",
    "promote:downloads": "functions-python/venv/bin/python3 scripts/promote-download-bundles.py",
    "prepare:og-region": "functions-python/venv/bin/python3 scripts/prepare-og-region-inputs.py",
    "check:og-region-bundle": "npx tsx scripts/verify-og-region-bundle.ts",
    "promote:og-region": "functions-python/venv/bin/python3 scripts/promote-og-region.py",
    "upload:genomes": "functions-python/venv/bin/python3 scripts/upload-genome-files.py",
    "check:py": "functions-python/venv/bin/python3 -m pytest -q functions-python/tests",
    "check:all": "npm run lint && npm run type-check && npm run check:arch && npm run check:traits-schema && npm run check:manifest-freshness && npm run check:cross-language && npm run check:py",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.8.0",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
