rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /cultivars/{cultivarId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Public grouping results. Written only by Cloud Functions (admin SDK bypasses rules).
    match /groupings/{traitId} {
      allow read: if true;
      allow write: if false;
    }
    match /_grouping_meta/{docId} {
      allow read, write: if false;
    }

    // Orthogroup differential analysis results. Public read.
    match /orthogroup_diffs/{traitId} {
      allow read: if true;
      allow write: if false;
    }

    // Analysis-workflow runs (5-step module). Run headers + candidate
    // subcollection are public-read; writes go through the admin SDK in
    // scripts/build-analysis-run.py.
    match /analysis_runs/{runId} {
      allow read: if true;
      allow write: if false;
    }
    match /analysis_runs/{runId}/candidates/{candidateId} {
      allow read: if true;
      allow write: if false;
    }

    // Entity → analysis-runs reverse index (og_*, gene_*, region_*, sv_*).
    // Powers the "Observed in Analyses" panel on entity pages.
    match /entity_analysis_index/{entityKey} {
      allow read: if true;
      allow write: if false;
    }

    // SV-matrix release headers (Phase 3). Storage bundles live under
    // sv_matrix/{svReleaseId}/** and have their own rule.
    match /sv_releases/{svReleaseId} {
      allow read: if true;
      allow write: if false;
    }

    // Orthofinder state: admin-only read (exposes processing status + file paths).
    match /_orthofinder_meta/state {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }
    match /_orthofinder_meta/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
