rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /genomes/{cultivarId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orthofinder staging: admin-only upload + read (cleaned up after commit).
    match /orthofinder/staging/{uploadId}/{file} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    // Committed orthofinder versions: public read for every non-staging top-level dir
    // under /orthofinder (i.e. v0, v1, v2, ...). Recursive match so nested artifacts
    // like og-members/chunk_000.json are allowed. Writes are always denied.
    match /orthofinder/{versionDir}/{path=**} {
      allow read: if versionDir != 'staging';
      allow write: if false;
    }

    // Orthogroup diff payloads (public read; written server-side only).
    match /orthogroup_diffs/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Allele frequency payloads (public read; written server-side only).
    match /og_allele_freq/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Pangenome tube map payloads (public read; written server-side only).
    match /og_tubemap/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Per-OG cultivar gene coordinate index (public read; written server-side only).
    match /og_gene_coords/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Gene → orthogroup reverse index (public read; built by scripts/build-gene-og-index.py).
    match /gene_index/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Gene model + functional annotation index (public read; built by
    // scripts/build-gene-models.py from funannotate_v2 GFF3).
    match /gene_models/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Compact functional search index (gzipped; built by
    // scripts/build-functional-search-index.py on top of gene_models).
    match /functional_index/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // OG → trait hits (p < threshold) — compact badge index
    // (gzipped; built by scripts/build-trait-hits-index.py).
    match /trait_hits/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Per-OG cluster region data (graph + AF bundle; public read; written server-side only).
    match /og_region/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // OG region v2 — trait-split + version-namespaced. Staging prefixes
    // are deliberately denied so stray uploads there are never publicly
    // linkable. Promoted prefixes (og_region_graph/v{of}_g{g}/,
    // og_region_af/v{of}_g{g}/) are public-read.
    match /og_region_graph/_staging/{path=**} {
      allow read, write: if false;
    }
    match /og_region_graph/{path=**} {
      allow read: if true;
      allow write: if false;
    }
    match /og_region_af/_staging/{path=**} {
      allow read, write: if false;
    }
    match /og_region_af/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Analysis-workflow bundles (per-candidate gzipped evidence + any run
    // exports). Public read; writes go through the admin SDK in
    // scripts/build-analysis-run.py.
    match /analysis_runs/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Discovery result downloads (public read; written by scripts/generate-download-bundles.py).
    // Files live under downloads/traits/{trait}/v{of}_g{g}/ and downloads/cross-trait/v{of}_g{g}/.
    // Bundle manifest at downloads/_manifest.json drives the /download UI.
    // Staging prefix downloads/_staging/** is deliberately NOT readable — it holds pre-promotion
    // artifacts that must not be linkable until verification passes.
    match /downloads/_staging/{path=**} {
      allow read, write: if false;
    }
    match /downloads/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
