rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /genomes/{cultivarId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orthofinder staging: admin-only upload + read (cleaned up after commit).
    match /orthofinder/staging/{uploadId}/{file} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    // Committed orthofinder versions: public read for matrix/gene drilldown.
    match /orthofinder/v{version}/{file} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
