rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /genomes/{cultivarId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orthofinder staging: admin-only upload + read (cleaned up after commit).
    match /orthofinder/staging/{uploadId}/{file} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    // Committed orthofinder versions: public read for every non-staging top-level dir
    // under /orthofinder (i.e. v0, v1, v2, ...). Recursive match so nested artifacts
    // like og-members/chunk_000.json are allowed. Writes are always denied.
    match /orthofinder/{versionDir}/{path=**} {
      allow read: if versionDir != 'staging';
      allow write: if false;
    }

    // Orthogroup diff payloads (public read; written server-side only).
    match /orthogroup_diffs/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Allele frequency payloads (public read; written server-side only).
    match /og_allele_freq/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Pangenome tube map payloads (public read; written server-side only).
    match /og_tubemap/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Per-OG cultivar gene coordinate index (public read; written server-side only).
    match /og_gene_coords/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Per-OG cluster region data (graph + AF bundle; public read; written server-side only).
    match /og_region/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
